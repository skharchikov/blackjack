# .understandignore — patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore (globs, # comments, ! negation, trailing / for dirs)
# Lines below are suggestions — uncomment to activate.
# Use ! prefix to force-include something excluded by defaults.
#
# Built-in defaults (always excluded unless negated):
#   node_modules/, .git/, dist/, build/, obj/, *.lock, *.min.js, etc.
#
# --- From .gitignore (uncomment to exclude) ---

# /target/            # Ignore the compiled files generated by Rust in the target directory
# **/*.rs.bk          # Ignore backup files for Rust source code
# Cargo.lock          # Ignore Cargo.lock file for libraries (not for binary projects)
# core/target/        # Ignore compiled files for the core module
# server/target/      # Ignore compiled files for the server module
# **/.cache/          # Ignore cache directories created by various tools
# .vscode/            # Ignore VSCode configuration files
# .idea/              # Ignore JetBrains IDE (like IntelliJ) configuration files
# *.iml               # Ignore IntelliJ project configuration files
# *.swp               # Ignore Vim temporary swap files
# *.log               # Ignore all log files
# .DS_Store           # Ignore macOS system files used for storing folder settings
# *.tmp               # Ignore temporary files
# *.bak               # Ignore backup files
# *.env
# .ai
# .claude
# blackjack-cli.log
# docs/

# --- Detected directories (uncomment to exclude) ---

# docs/
# migrations/

